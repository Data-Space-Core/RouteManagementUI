{
  "clientId": "route-management-ui",
  "name": "Route Management UI",
  "description": "Django web UI for tenant route management",
  "rootUrl": "https://tenant-a.dil.collab-cloud.eu/route",
  "baseUrl": "https://tenant-a.dil.collab-cloud.eu/route",
  "adminUrl": "https://tenant-a.dil.collab-cloud.eu/route",
  "enabled": true,
  "protocol": "openid-connect",
  "publicClient": false,
  "standardFlowEnabled": true,
  "directAccessGrantsEnabled": false,
  "serviceAccountsEnabled": false,
  "implicitFlowEnabled": false,
  "redirectUris": [
    "https://tenant-a.dil.collab-cloud.eu/route/oidc/callback/"
  ],
  "webOrigins": [
    "https://tenant-a.dil.collab-cloud.eu"
  ],
  "attributes": {
    "pkce.code.challenge.method": "S256",
    "post.logout.redirect.uris": "https://tenant-a.dil.collab-cloud.eu/*"
  },
  "defaultClientScopes": [
    "web-origins",
    "profile",
    "email",
    "roles"
  ],
  "optionalClientScopes": [
    "address",
    "phone",
    "offline_access",
    "microprofile-jwt"
  ]
}
